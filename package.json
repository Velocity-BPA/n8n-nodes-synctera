{
  "name": "n8n-nodes-synctera",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Synctera Banking-as-a-Service (BaaS) platform providing 29 resources and 200+ operations for customer management, account operations, ACH/wire transfers, card issuing, spend controls, KYC verification, watchlist screening, and webhook integration.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-synctera.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-synctera",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-synctera/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "synctera",
    "baas",
    "banking-as-a-service",
    "fintech",
    "banking",
    "payments",
    "ach",
    "wire",
    "cards",
    "kyc",
    "aml",
    "compliance",
    "accounts",
    "transactions"
  ],
  "main": "dist/nodes/Synctera/Synctera.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SyncteraApi.credentials.js",
      "dist/credentials/SyncteraOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Synctera/Synctera.node.js",
      "dist/nodes/Synctera/SyncteraTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.35.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
